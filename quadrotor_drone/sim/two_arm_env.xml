<mujoco model="two_arm_2d_cooperative">
  <compiler angle="radian" coordinate="local" inertiafromgeom="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4" cone="elliptic"/>
  <size njmax="1000" nconmax="400"/>

  <default>
    <joint damping="3" armature="0.03" limited="true"/>
    <geom condim="6" density="600" friction="4 0.05 0.005"
          solref="0.005 1" solimp="0.95 0.99 0.001"/>
  </default>

  <contact>
    <exclude body1="base_L" body2="link1_L"/>
    <exclude body1="link1_L" body2="link2_L"/>
    <exclude body1="link2_L" body2="link3_L"/>

    <exclude body1="base_R" body2="link1_R"/>
    <exclude body1="link1_R" body2="link2_R"/>
    <exclude body1="link2_R" body2="link3_R"/>
  </contact>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" diffuse="1 1 1"/>
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.95 0.95 0.95 1"/>

    <geom name="workspace" type="box" pos="0 0 0.005"
          size="2 2 0.005" rgba="0.85 0.85 0.85 1" contype="0" conaffinity="0"/>

    <!-- Кубик, который переносим -->
    <body name="cube" pos="0 -0.25 0.08">
      <joint name="cube_x" type="slide" axis="1 0 0" range="-0.75 0.75" damping="0.5"/>
      <joint name="cube_y" type="slide" axis="0 1 0" range="-0.50 0.50" damping="0.5"/>

      <geom name="cube_geom" type="box" size="0.02 0.02 0.02"
            rgba="0.1 0.75 0.1 1"
            friction="8 0.1 0.01"
            solref="0.005 1"
            solimp="0.95 0.99 0.001"/>
    </body>

    <!-- Точка передачи: зелёный шар -->
    <site name="transfer_site" pos="0 0.03 0.06" size="0.02" rgba="0 1 0 0.9"/>

    <!-- Финальная цель: зелёный квадрат -->
    <geom name="final_area" type="box" pos="0.235 0.24 0.012"
          size="0.07 0.07 0.002" rgba="0 1 0 0.35" contype="0" conaffinity="0"/>
    <site name="final_site" pos="0.235 0.24 0.06" size="0.02" rgba="0 1 0 0.9"/>

    <!-- LEFT ARM -->
    <body name="base_L" pos="-0.50 -0.08 0.08">
      <geom name="base_geom_L" type="cylinder" size="0.045 0.025"
            rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>
      <joint name="j1_L" type="hinge" axis="0 0 1" range="-3.14 3.14"/>

      <body name="link1_L" pos="0 0 0">
        <geom name="l1_L" type="capsule" fromto="0 0 0  0.25 0 0"
              size="0.018" rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>

        <body name="link2_L" pos="0.25 0 0">
          <joint name="j2_L" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
          <geom name="l2_L" type="capsule" fromto="0 0 0  0.22 0 0"
                size="0.016" rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>

          <body name="link3_L" pos="0.22 0 0">
            <joint name="j3_L" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
            <geom name="l3_L" type="capsule" fromto="0 0 0  0.14 0 0"
                  size="0.014" rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>

            <site name="ee_L" pos="0.14 0 0" size="0.008" rgba="1 0 0 1"/>

            <body name="gripper_L" pos="0.14 0 0">
              <geom name="palm_L" type="box" size="0.015 0.04 0.02"
                    rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>

              <body name="finger_left_L" pos="0.04 0.03 0">
                <joint name="jfL_L" type="slide" axis="0 1 0" range="-0.04 0.04"/>
                <geom name="fingerL_L" type="box" size="0.04 0.010 0.012"
                      pos="0 0.020 0" rgba="0.15 0.15 0.15 1"
                      friction="10 0.1 0.01"/>
              </body>

              <body name="finger_right_L" pos="0.04 0.01 0">
                <joint name="jfR_L" type="slide" axis="0 -1 0" range="-0.04 0.04"/>
                <geom name="fingerR_L" type="box" size="0.04 0.010 0.012"
                      pos="0 -0.020 0" rgba="0.15 0.15 0.15 1"
                      friction="10 0.1 0.01"/>
              </body>

              <site name="grasp_L" pos="0.04 0 0" size="0.008" rgba="0 0 1 1"/>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- RIGHT ARM -->
    <body name="base_R" pos="0.50 -0.08 0.08" euler="0 0 3.14159">
      <geom name="base_geom_R" type="cylinder" size="0.045 0.025"
            rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>
      <joint name="j1_R" type="hinge" axis="0 0 1" range="-3.14 3.14"/>

      <body name="link1_R" pos="0 0 0">
        <geom name="l1_R" type="capsule" fromto="0 0 0  0.25 0 0"
              size="0.018" rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>

        <body name="link2_R" pos="0.25 0 0">
          <joint name="j2_R" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
          <geom name="l2_R" type="capsule" fromto="0 0 0  0.22 0 0"
                size="0.016" rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>

          <body name="link3_R" pos="0.22 0 0">
            <joint name="j3_R" type="hinge" axis="0 0 1" range="-3.14 3.14"/>
            <geom name="l3_R" type="capsule" fromto="0 0 0  0.14 0 0"
                  size="0.014" rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>

            <site name="ee_R" pos="0.14 0 0" size="0.008" rgba="1 0 0 1"/>

            <body name="gripper_R" pos="0.14 0 0">
              <geom name="palm_R" type="box" size="0.015 0.04 0.02"
                    rgba="0.15 0.15 0.15 1" contype="0" conaffinity="0"/>

              <body name="finger_left_R" pos="0.04 0.03 0">
                <joint name="jfL_R" type="slide" axis="0 1 0" range="-0.04 0.04"/>
                <geom name="fingerL_R" type="box" size="0.04 0.010 0.012"
                      pos="0 0.020 0" rgba="0.15 0.15 0.15 1"
                      friction="10 0.1 0.01"/>
              </body>

              <body name="finger_right_R" pos="0.04 0.01 0">
                <joint name="jfR_R" type="slide" axis="0 -1 0" range="-0.04 0.04"/>
                <geom name="fingerR_R" type="box" size="0.04 0.010 0.012"
                      pos="0 -0.020 0" rgba="0.15 0.15 0.15 1"
                      friction="10 0.1 0.01"/>
              </body>

              <site name="grasp_R" pos="0.04 0 0" size="0.008" rgba="0 0 1 1"/>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="a_j1_L" joint="j1_L" kp="180" ctrlrange="-3.14 3.14" dampratio="1"/>
    <position name="a_j2_L" joint="j2_L" kp="160" ctrlrange="-2.4 2.4" dampratio="1"/>
    <position name="a_j3_L" joint="j3_L" kp="140" ctrlrange="-2.4 2.4" dampratio="1"/>

    <position name="a_j1_R" joint="j1_R" kp="180" ctrlrange="-3.14 3.14" dampratio="1"/>
    <position name="a_j2_R" joint="j2_R" kp="160" ctrlrange="-2.4 2.4" dampratio="1"/>
    <position name="a_j3_R" joint="j3_R" kp="140" ctrlrange="-2.4 2.4" dampratio="1"/>

    <position name="a_fL_L" joint="jfL_L" kp="1200" ctrlrange="-0.04 0" forcerange="-200 200"/>
    <position name="a_fR_L" joint="jfR_L" kp="1200" ctrlrange="0 0.04" forcerange="-200 200"/>

    <position name="a_fL_R" joint="jfL_R" kp="1200" ctrlrange="-0.04 0" forcerange="-200 200"/>
    <position name="a_fR_R" joint="jfR_R" kp="1200" ctrlrange="0 0.04" forcerange="-200 200"/>
  </actuator>
</mujoco>